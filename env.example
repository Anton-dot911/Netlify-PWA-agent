# ─── Anthropic ────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Dune Analytics ───────────────────────────────────────────
# Query API key: https://dune.com/settings/api
DUNE_API_KEY=your_dune_query_api_key

# Sim API key (separate from Query API):
# https://dune.com/settings/api → Sim API tab
DUNE_SIM_API_KEY=your_dune_sim_api_key

# ─── Optional ─────────────────────────────────────────────────
NODE_ENV=development
